NODE_ENV=development   # usar "production" no Render
HOST=127.0.0.1
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Local PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=sua_senha
DB_NAME=cantina

# Render/PostgreSQL hospedado
# Em producao, prefira configurar DATABASE_URL no painel do Render.
# DATABASE_URL=postgresql://usuario:senha@host:5432/cantina

JWT_SECRET=troque_este_segredo
JWT_EXPIRES_IN=8h
CANTINA_REGISTER_KEY=troque_esta_chave_admin
GOOGLE_CLIENT_ID=
HISTORICO_DIAS=7

# E-mail via Resend (opcional — sem RESEND_API_KEY os emails são apenas logados no console)
# Crie uma conta em resend.com e gere uma API key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
RESEND_FROM=CantinaGO <onboarding@resend.dev>
FRONTEND_URL=http://localhost:5173
