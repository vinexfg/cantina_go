# Copie este arquivo para .env e preencha os valores

# ID do cliente Google OAuth2 (obtenha em console.cloud.google.com)
# Deixe em branco para desativar o login com Google
VITE_GOOGLE_CLIENT_ID=

# URL da API em producao.
# Localmente, se deixar vazio, o front usa /api com o proxy do Vite.
VITE_API_URL=https://seu-backend.onrender.com/api
